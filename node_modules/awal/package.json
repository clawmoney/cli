{
  "name": "awal",
  "version": "2.2.0",
  "type": "module",
  "description": "Coinbase Wallet CLI for payments and crypto",
  "bin": {
    "awal": "dist/index.js"
  },
  "files": [
    "dist/",
    "server-bundle/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@x402/core": "^2.4.0",
    "@x402/extensions": "^2.4.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "env-paths": "^3.0.0",
    "ora": "^8.0.0",
    "viem": "^2.37.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "tsx": "^4.20.3",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coinbase/awal.git"
  },
  "keywords": [
    "wallet",
    "coinbase",
    "crypto",
    "payments",
    "x402",
    "usdc",
    "cli"
  ],
  "author": "Coinbase",
  "license": "Apache-2.0"
}
